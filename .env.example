# 로컬에서는 생략하면 sqlite:///./localhub.db를 사용합니다.
DATABASE_URL=sqlite:///./localhub.db

# Vue 개발 서버와 배포 도메인을 쉼표로 구분합니다. 끝에 /를 붙이지 마세요.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 챗봇 API에 필요합니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# posts 테이블이 비어 있을 때 자동 생성하는 더미 게시글의 공통 비밀번호입니다.
DUMMY_POST_PASSWORD=dummy1234

APP_ENV=development
